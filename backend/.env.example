NODE_ENV=development
PORT=3000
HOST=0.0.0.0

# Comma-separated list or single origin. Example: http://localhost:5173
CORS_ORIGIN=http://localhost:5173

# Use strong secrets in production (32+ random bytes).
JWT_ACCESS_SECRET=change_me_access
JWT_REFRESH_SECRET=change_me_refresh
COOKIE_SECRET=change_me_cookie

# Postgres (Prisma)
#
# Local example:
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/techm4schools?schema=public
#
# Supabase Postgres example (IMPORTANT: add sslmode=require):
# DATABASE_URL=postgresql://postgres:<PASSWORD>@db.<PROJECT_REF>.supabase.co:5432/postgres?sslmode=require
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/techm4schools?schema=public

# Redis
REDIS_URL=redis://localhost:6379

# Token TTLs
ACCESS_TOKEN_TTL_SEC=900
REFRESH_TOKEN_TTL_SEC=2592000

# Rate limit (per IP)
RATE_LIMIT_MAX=300
RATE_LIMIT_TIME_WINDOW_MS=60000

